@model IEnumerable<TEMSystem.Models.Event>

<div class="container mt-5">

    <h3 class="fw-bold mb-4 text-center">Eventos Disponibles</h3>

    <div class="row g-4">
        @foreach (var e in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-lg border-0 rounded-4">

                    <img src="@e.ImagenUrl" class="card-img-top rounded-top-4" style="height: 200px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold">@e.Nombre</h5>

                        <p class="card-text text-muted" style="flex-grow: 1;">
                            @e.Descripcion
                        </p>

                        <div class="mt-3">
                            <p class="mb-1">
                                <strong>📅</strong> @e.Fecha.ToString("dd/MM/yyyy HH:mm")
                            </p>

                            <p class="mb-0">
                                <strong>📍</strong> @e.Ubicacion
                            </p>
                        </div>

                    </div>

                </div>
            </div>
        }
    </div>

</div>