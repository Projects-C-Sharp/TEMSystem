<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventra</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            background: transparent;
            color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        /* ===== NAVBAR GLASS ===== */
        .navbar-glass {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;

            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);

            border-bottom: 1px solid rgba(255,255,255,0.1);

            transition: all 0.4s ease;
            opacity: 0.4;
        }

        /* Aparece al hover */
        .navbar-glass:hover {
            opacity: 1;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(18px);
        }

        /* LOGO */
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: bold;
            font-size: 1.3rem;
        }

        .logo-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #00eaff, #ff00c8);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            animation: pulse 2s infinite;
        }

        .logo-text {
            background: linear-gradient(90deg, #00eaff, #ff00c8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* LINKS */
        .nav-link {
            color: #fff !important;
            transition: 0.3s;
            position: relative;
        }

        .nav-link:hover {
            color: #00eaff !important;
            transform: translateY(-2px);
        }

        /* Línea animada hover */
        .nav-link::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: -3px;
            width: 0%;
            height: 2px;
            background: linear-gradient(90deg, #00eaff, #ff00c8);
            transition: 0.3s;
        }

        .nav-link:hover::after {
            width: 100%;
        }

        /* CONTENIDO */
        main {
            min-height: 100vh;
            position: relative;
            z-index: 5;
        }

        /* FOOTER GLASS */
        footer {
            position: relative;
            z-index: 5;
            text-align: center;
            padding: 20px;

            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        footer a {
            color: #00eaff;
            text-decoration: none;
        }

        /* ANIMACIÓN LOGO */
        @@keyframes pulse {
            0% { box-shadow: 0 0 10px rgba(0,234,255,0.4); }
            50% { box-shadow: 0 0 20px rgba(255,0,200,0.7); }
            100% { box-shadow: 0 0 10px rgba(0,234,255,0.4); }
        }
        .Admin:hover{
            transform: scale(1.05);
        }
    </style>

</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-glass">
            <div class="container-fluid">

                <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                    <div class="logo-icon">
                        <i class="bi bi-calendar-event"></i>
                    </div>
                    <span class="logo-text">Eventra</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-flex justify-content-end">
                    <ul class="navbar-nav">
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Event" asp-action="Public">Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link Admin" asp-controller="Event" asp-action="Index">Admin</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- CONTENIDO (IMPORTANTE: sin container global) -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <p>&copy; 2026 - Eventra</p>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>