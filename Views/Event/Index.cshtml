@model IEnumerable<TEMSystem.Models.Event>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Eventos</h3>
        <a class="btn btn-success" href="/Event/Create">
            + Nuevo Evento
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Fecha</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                    </thead>

                    <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@e.Nombre</td>
                            <td>@e.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn btn-warning btn-sm" href="/Event/Edit/@e.Id">
                                        Editar
                                    </a>

                                    <a class="btn btn-danger btn-sm" href="/Event/Delete/@e.Id">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>