@model IEnumerable<TEMSystem.Models.Event>

<style>
    /* ===== FONDO ===== */
    .events-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
    }

    .events-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.35);
    }

    .events-overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        background: rgba(0,0,0,0.6);
        pointer-events: none;
    }

    /* ===== CONTENIDO ===== */
    .events-container {
        position: relative;
        z-index: 2;
        margin-top: 100px;
        padding-bottom: 50px;
    }

    .title {
        text-align: center;
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 40px;
        background: linear-gradient(90deg, #00eaff, #ff00c8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ===== CARD ===== */
    .event-card {
        border-radius: 20px;
        overflow: hidden;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,0.15);
        transition: 0.4s;
        height: 100%;
    }

    .event-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    }

    .event-img {
        height: 220px;
        width: 100%;
        object-fit: cover;
        transition: 0.4s;
    }

    .event-card:hover .event-img {
        transform: scale(1.1);
    }

    .img-overlay {
        position: absolute;
        top: 0;
        width: 100%;
        height: 220px;
        background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.85));
    }

    .event-body {
        padding: 20px;
        color: white;
    }

    .event-title {
        font-weight: bold;
        font-size: 1.2rem;
    }

    .event-desc {
        font-size: 0.95rem;
        color: #ccc;
        margin-top: 10px;
    }

    .event-info {
        margin-top: 15px;
        font-size: 0.9rem;
        color: #ddd;
    }

    /* ===== BOTONES ADMIN ===== */
    .btn-admin-group {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    .btn-admin {
        flex: 1;
        padding: 8px;
        border-radius: 25px;
        border: none;
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: 0.3s;
        color: white;
    }

    .btn-edit {
        background: linear-gradient(90deg, #ffb100, #ff7b00);
    }

    .btn-delete {
        background: linear-gradient(90deg, #ff3b3b, #c40000);
    }

    .btn-admin:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px rgba(255,255,255,0.2);
        color: white;
    }

    /* ===== BOTÓN CREAR ===== */
    .btn-create {
        display: block;
        margin: 0 auto 30px auto;
        width: fit-content;
        padding: 10px 20px;
        border-radius: 30px;
        border: none;

        background: linear-gradient(90deg, #00eaff, #ff00c8);
        color: white;
        font-weight: 600;
        text-decoration: none;

        transition: 0.3s;
    }

    .btn-create:hover {
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(255,0,200,0.6);
        color: white;
    }

</style>

<!-- FONDO -->
<div class="events-bg">
    <img src="~/images/fondo.gif" />
</div>

<div class="events-overlay"></div>

<!-- CONTENIDO -->
<div class="container events-container">

    <h2 class="title">Admin · Eventos</h2>

    <a class="btn-create" href="/Event/Create">
        + Crear Evento
    </a>

    <div class="row g-4">
        @foreach (var e in Model)
        {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="event-card">

                <div class="position-relative">
                    <img src="@e.ImagenUrl" class="event-img" />
                    <div class="img-overlay"></div>
                </div>

                <div class="event-body">

                    <div class="event-title">@e.Nombre.ToUpper()</div>

                    <div class="event-desc">
                        @e.Descripcion
                    </div>

                    <div class="event-info">
                        <div>📅 @e.Fecha.ToString("dd MMM yyyy - HH:mm")</div>
                        <div>📍 @e.Ubicacion</div>
                    </div>

                    <div class="btn-admin-group">
                        <a class="btn-admin btn-edit"
                           href="/Event/Edit/@e.Id">
                            Editar
                        </a>

                        <a class="btn-admin btn-delete"
                           href="/Event/Delete/@e.Id">
                            Eliminar
                        </a>
                    </div>

                </div>

            </div>
        </div>
        }
    </div>

</div>