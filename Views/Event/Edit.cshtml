@model TEMSystem.Models.Event

<style>
    /* ===== FONDO ===== */
    .admin-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
    }

    .admin-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.35);
    }

    .admin-overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        background: rgba(0,0,0,0.65);
    }

    /* ===== CONTENEDOR ===== */
    .admin-container {
        position: relative;
        z-index: 2;
        min-height: 100vh;

        display: flex;
        align-items: center;
        justify-content: center;

        padding: 40px 20px;
    }

    /* ===== CARD GLASS ===== */
    .admin-card {
        width: 100%;
        max-width: 750px;

        border-radius: 25px;
        padding: 35px;

        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(20px);

        border: 1px solid rgba(255,255,255,0.2);

        color: white;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }

    /* ===== HEADER ===== */
    .admin-title {
        text-align: center;
        font-size: 2rem;
        font-weight: bold;

        margin-bottom: 10px;

        background: linear-gradient(90deg, #ffb100, #ff6a00);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .admin-subtitle {
        text-align: center;
        color: #aaa;
        margin-bottom: 25px;
        font-size: 0.95rem;
    }

    /* ===== INPUTS ===== */
    .form-control {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.15);
        color: white;
        border-radius: 12px;
        padding: 12px;
        transition: 0.3s;
    }

    .form-control:focus {
        background: rgba(255,255,255,0.12);
        border-color: #ffb100;
        box-shadow: 0 0 15px rgba(255,177,0,0.4);
        color: white;
    }

    .form-control::placeholder {
        color: rgba(255,255,255,0.6);
    }

    .form-label {
        color: #ddd;
        margin-bottom: 6px;
        font-size: 0.9rem;
    }

    textarea.form-control {
        resize: none;
    }

    /* ===== BOTONES ===== */
    .btn-admin {
        width: 100%;
        padding: 12px;
        border-radius: 30px;
        border: none;
        font-weight: 600;
        transition: 0.3s;
        color: white;
    }

    .btn-update {
        background: linear-gradient(90deg, #ffb100, #ff6a00);
    }

    .btn-update:hover {
        transform: scale(1.03);
        box-shadow: 0 0 25px rgba(255,177,0,0.5);
    }

    .btn-cancel {
        background: rgba(255,255,255,0.15);
    }

    .btn-cancel:hover {
        transform: scale(1.03);
        background: rgba(255,255,255,0.25);
    }

    /* ===== INPUT GROUP SPACING ===== */
    .form-group {
        margin-bottom: 18px;
    }

    /* ===== BUTTON ROW ===== */
    .btn-row {
        display: flex;
        gap: 12px;
        margin-top: 10px;
    }
</style>

<!-- FONDO -->
<div class="admin-bg">
    <img src="~/images/fondo.gif" />
</div>
<div class="admin-overlay"></div>

<!-- CONTENIDO -->
<div class="admin-container">

    <div class="admin-card">

        <div class="admin-title">Editar Evento</div>

        <div class="admin-subtitle">
            Modifica la información del evento seleccionado
        </div>

        <form method="post">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label class="form-label">Nombre del evento</label>
                <input asp-for="Nombre" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Fecha</label>
                <input asp-for="Fecha" type="datetime-local" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Ubicación</label>
                <input asp-for="Ubicacion" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Imagen URL</label>
                <input asp-for="ImagenUrl" class="form-control" />
            </div>

            <div class="form-group">
                <label class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" rows="4" class="form-control"></textarea>
            </div>

            <div class="btn-row">

                <button type="submit" class="btn-admin btn-update">
                    Actualizar Evento
                </button>

                <a href="/Event/Index" class="btn-admin btn-cancel text-center text-decoration-none">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</div>