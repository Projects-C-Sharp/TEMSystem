@{
    ViewData["Title"] = "Inicio";
}

<style>
    /* ====== VIDEO DE FONDO ====== */
    .bg-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        overflow: hidden;
    }

    .bg-video video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.55) contrast(1.2) saturate(1.3);
        transform: scale(1.1);
    }

    /* Overlay oscuro suave */
    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 2;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, rgba(255,0,200,0.15), rgba(0,0,0,0.75));
    }

    /* ====== CONTENIDO CENTRADO ====== */
    .hero-wrapper {
        position: relative;
        z-index: 3;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    /* ====== GLASS CARD ====== */
    .glass-card {
        width: 100%;
        max-width: 900px;
        padding: 40px;
        border-radius: 20px;

        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);

        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);

        text-align: center;
        animation: fadeUp 1s ease;
    }

    /* TITULO */
    .glass-card h1 {
        font-size: 3rem;
        font-weight: bold;
        background: linear-gradient(90deg, #00eaff, #ff00c8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .glass-card p {
        color: #eaeaea;
        font-size: 1.2rem;
        margin-top: 10px;
    }

    /* BOTÓN */
    .btn-event {
        margin-top: 25px;
        padding: 14px 35px;
        font-size: 1.1rem;
        border-radius: 40px;
        border: none;
        background: linear-gradient(90deg, #00eaff, #ff00c8);
        color: white;
        text-decoration: none;
        display: inline-block;
        transition: 0.3s;
        box-shadow: 0 0 20px rgba(255,0,200,0.4);
    }

    .btn-event:hover {
        transform: scale(1.1);
        box-shadow: 0 0 35px rgba(0,234,255,0.9);
    }

    /* FEATURES */
    .features {
        margin-top: 40px;
    }

    .feature-item {
        padding: 15px;
        border-radius: 12px;
        background: rgba(255,255,255,0.05);
        transition: 0.3s;
    }

    .feature-item:hover {
        transform: translateY(-5px);
        background: rgba(255,255,255,0.1);
    }

    .feature-item i {
        font-size: 2rem;
        color: #00eaff;
    }

    /* ANIMACION */
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<!-- VIDEO BACKGROUND -->
<div class="bg-video">
    <video autoplay muted loop playsinline>
        <source src="/video/evento.mp4" type="video/mp4">
    </video>
</div>

<div class="bg-overlay"></div>

<!-- GLASS CONTENT -->
<div class="hero-wrapper">

    <div class="glass-card">

        <h1>Eventra</h1>
        <p>Descubre eventos, conciertos y experiencias únicas cerca de ti</p>

        <a asp-controller="Event" asp-action="Public" class="btn-event">
            Explorar Eventos
        </a>

        <!-- FEATURES -->
        <div class="row features mt-4 g-3">
            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-calendar-event"></i>
                    <h6 class="mt-2">Eventos en vivo</h6>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-people"></i>
                    <h6 class="mt-2">Conecta</h6>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-item">
                    <i class="bi bi-geo-alt"></i>
                    <h6 class="mt-2">Cerca de ti</h6>
                </div>
            </div>
        </div>

    </div>
</div>